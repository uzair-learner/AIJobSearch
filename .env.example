APP_NAME=VisaSponsor Jobs API
ENVIRONMENT=development
FRONTEND_URL=http://127.0.0.1:5173
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
ADMIN_TOKEN=change-me
DATABASE_URL=sqlite:///./visa_sponsor_jobs.db
REDIS_URL=redis://redis:6379/0
ENABLE_DEMO_SEED=true
MAX_UPLOAD_SIZE_MB=20
REQUEST_RATE_LIMIT=120
REQUEST_RATE_WINDOW_SECONDS=60
CURRENT_JOBS_REFRESH_MINUTES=180
GOVERNMENT_REFRESH_HOURS=24
VITE_API_BASE_URL=http://127.0.0.1:8000/api
VITE_ADMIN_TOKEN=change-me
